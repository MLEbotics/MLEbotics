---
const links = [
  { label: 'Projects',     href: '/projects' },
  { label: 'Blog',         href: '/blog' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'About',        href: '/about' },
  { label: 'Studio',       href: 'https://studio.mlebotics.com' },
  { label: 'Docs',         href: 'https://docs.mlebotics.com' },
]
const current = Astro.url.pathname
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="MLEbotics home">
      <img src="/chevrons.png" alt="" class="logo__mark" width="22" height="22" />
      <span>MLEbotics</span>
    </a>
    <nav class="nav" aria-label="Main navigation">
      {links.map(l => (
        <a href={l.href} class={`nav__link${current.startsWith(l.href) ? ' active' : ''}`}>{l.label}</a>
      ))}
    </nav>
    <a href="https://console.mlebotics.com" class="btn-outline btn--sm">Dashboard &rarr;</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(14px);
    background: rgba(6,8,15,.85);
    border-bottom: 1px solid var(--border);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 64px;
  }
  .logo {
    font-family: 'Orbitron', monospace;
    font-size: .9rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: .06em;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
  }
  .logo__mark {
    display: block;
    height: 22px;
    width: 22px;
  }
  .nav { display: flex; gap: 1.5rem; flex: 1; }
  .nav__link {
    font-size: .875rem;
    color: var(--muted);
    text-decoration: none;
    transition: color .15s;
    padding: .25rem 0;
    border-bottom: 2px solid transparent;
  }
  .nav__link:hover { color: #fff; }
  .nav__link.active { color: #fff; border-bottom-color: var(--cyan); }
  .btn--sm { padding: .45rem 1rem; font-size: .8rem; flex-shrink: 0; }
</style>
