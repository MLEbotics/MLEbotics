---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import PostReader from '@components/PostReader'
---

<Layout
  title="Blog Post"
  description="Read the latest posts from MLEbotics."
>
  <Header />

  <main>
    <section class="section">
      <div class="container">
        <PostReader client:load />
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Rendered markdown body styles */
  :global(.post-body h1),
  :global(.post-body h2),
  :global(.post-body h3) {
    color: #fff;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: .75rem;
    line-height: 1.3;
  }
  :global(.post-body h1) { font-size: 1.6rem; }
  :global(.post-body h2) { font-size: 1.3rem; }
  :global(.post-body h3) { font-size: 1.1rem; }
  :global(.post-body p) {
    margin-bottom: 1.2rem;
    color: #cbd5e1;
    line-height: 1.85;
  }
  :global(.post-body strong) { color: #fff; font-weight: 600; }
  :global(.post-body em) { color: #e2e8f0; font-style: italic; }
  :global(.post-body code) {
    background: rgba(0,212,255,.08);
    border: 1px solid rgba(0,212,255,.15);
    border-radius: 4px;
    padding: .15rem .4rem;
    font-size: .85em;
    color: var(--cyan);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  :global(.post-body pre) {
    background: rgba(0,0,0,.4);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  :global(.post-body pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #e2e8f0;
    font-size: .875rem;
  }
  :global(.post-body hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
</style>
