---
import Layout from '@layouts/Layout.astro'
import Header from '@components/Header.astro'
import Footer from '@components/Footer.astro'
import '../styles/global.css'
---

<Layout title="MLEbotics" description="Building modular AI, automation, and robotics tools that remove friction and make life easier.">
  <Header />

  <main>
    <!-- ── Hero ────────────────────────────────────────────────────── -->
    <section class="hero section">
      <div class="container hero__inner">
        <div class="hero__badge">
          <span class="dot"></span>
          AI · Automation · Humanoid Robotics
        </div>
        <h1 class="hero__h1">
          Remove friction.<br />
          <span class="gradient-text">Build smarter tools.</span>
        </h1>
        <p class="hero__sub">
          MLEbotics builds modular AI, automation, and robotics systems—<br />
          so you can focus on what matters, not on repetitive work.
        </p>
        <div class="hero__cta">
          <a href="/projects" class="btn-primary">See our projects</a>
          <a href="/about" class="btn-outline">About us</a>
        </div>
      </div>
      <div class="hero__glow" aria-hidden="true"></div>
    </section>

    <!-- ── Capabilities ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <p class="tag">What we build</p>
        <h2 class="section__h2">Modular tools for every layer</h2>
        <div class="grid3">
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#129302;</div>
            <h3>AI Agents</h3>
            <p>Context-aware agents that read, reason, and act — from scheduling to document processing to full desktop automation.</p>
          </div>
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#9881;&#65039;</div>
            <h3>Automation</h3>
            <p>End-to-end workflow automation: form filling, data extraction, notification routing, and API orchestration.</p>
          </div>
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#129302;</div>
            <h3>Robotics Firmware</h3>
            <p>Lightweight firmware and companion apps for physical robots — bridging embedded hardware to cloud intelligence.</p>
          </div>
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#128241;</div>
            <h3>Mobile Apps</h3>
            <p>Cross-platform Flutter applications — from running trackers to AI-powered coaching dashboards.</p>
          </div>
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#128202;</div>
            <h3>Dashboards</h3>
            <p>Real-time monitoring dashboards that surface the data you care about, without the noise you don't.</p>
          </div>
          <div class="card cap-card">
            <div class="cap-icon" aria-hidden="true">&#128279;</div>
            <h3>Integrations</h3>
            <p>Plug-and-play connectors for Telegram, Firebase, OpenAI, Anthropic, and your existing stack.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Projects preview ─────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <p class="tag">Featured projects</p>
        <h2 class="section__h2">Built at MLEbotics</h2>
        <div class="project-list">
          <a href="/projects#runcompanion" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Flutter · Firebase</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>RunCompanion</h3>
            <p>AI-powered running coach. Tracks pace, plans sessions, and syncs with robotics training hardware.</p>
          </a>
          <a href="/projects#autoformfiller" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Chrome · Flask</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>AutoFormFiller</h3>
            <p>Chrome extension + backend that automatically fills forms using AI — built for job applications and registrations.</p>
          </a>
          <a href="/projects#hey-girl" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Python · OpenAI</span>
              <span class="project-status active">Active</span>
            </div>
            <h3>Hey Girl</h3>
            <p>Voice AI assistant for Windows. Handles tasks, reads assignments, solves quizzes, and answers questions contextually.</p>
          </a>
          <a href="/projects#computer-use" class="card project-card">
            <div class="project-card__head">
              <span class="project-badge">Anthropic · Desktop</span>
              <span class="project-status wip">In Progress</span>
            </div>
            <h3>Computer Use Agent</h3>
            <p>Anthropic-powered AI desktop agent that sees your screen and completes tasks like a human operator.</p>
          </a>
        </div>
        <div style="margin-top:2.5rem;text-align:center;">
          <a href="/projects" class="btn-outline">View all projects &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ── CTA banner ────────────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <div class="cta-banner">
          <h2>See it in action</h2>
          <p>Explore the live dashboard to track projects, robots, and workflows in real time.</p>
          <a href="https://console.mlebotics.com" class="btn-primary">Open dashboard &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ── Community Chat ─────────────────────────────────────────── -->
    <section class="section">
      <div class="container">
        <div class="community-card">
          <div class="community-card__left">
            <p class="tag">Community</p>
            <h2 class="section__h2" style="margin-bottom:.75rem;">Build with us</h2>
            <p class="community-desc">Ask questions, share what you're building, show off projects, and connect with other MLEbotics builders — all in one place.</p>
            <button id="open-chat-btn" class="btn-primary community-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Open Community Chat
            </button>
          </div>
          <div class="community-card__right" aria-hidden="true">
            <div class="chat-preview">
              <div class="chat-msg bot">👋 Welcome to MLEbotics Community!</div>
              <div class="chat-msg user">Just launched my first automation agent 🚀</div>
              <div class="chat-msg bot">🤖 Love it! Share a link and we'll check it out.</div>
              <div class="chat-msg user">Integrating with BLE firmware now...</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<!-- Community Chat Floating Widget -->
<div id="chat-widget" class="chat-widget" hidden>
  <div class="chat-panel" id="chat-panel" hidden>
    <div class="chat-panel__header">
      <span class="chat-panel__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Community Chat
        <span class="chat-panel__badge">Preview</span>
      </span>
      <button id="close-chat" class="chat-close" aria-label="Close chat">&times;</button>
    </div>
    <!-- Name entry screen -->
    <div id="chat-name-screen" style="display:none;padding:1.5rem 1.25rem;">
      <div style="text-align:center;margin-bottom:1rem;"><div style="font-size:2rem;">👋</div><p style="color:#fff;font-weight:600;font-size:.95rem;margin:.4rem 0 .2rem;">What should we call you?</p><p style="color:#6b7280;font-size:.75rem;">Your name will show next to your messages.</p></div>
      <input id="chat-name-input" type="text" maxlength="30" placeholder="Enter your name…" autocomplete="off" style="width:100%;box-sizing:border-box;background:#1f2937;border:1px solid #374151;color:#f3f4f6;border-radius:8px;padding:.6rem .75rem;font-size:.85rem;outline:none;margin-bottom:.75rem;" />
      <div style="display:flex;gap:.5rem;" id="chat-name-btns">
        <button id="chat-name-save" style="flex:1;background:#06b6d4;border:none;color:#030712;font-weight:700;font-size:.85rem;border-radius:8px;padding:.6rem;cursor:pointer;">Join Chat</button>
      </div>
    </div>
    <!-- Name bar (shown after name is set) -->
    <div id="chat-name-bar" style="display:none;border-bottom:1px solid #1f2937;padding:.4rem 1rem;display:flex;align-items:center;justify-content:space-between;background:rgba(0,0,0,.2);">
      <span style="font-size:.7rem;color:#6b7280;">Chatting as <strong id="chat-name-display" style="color:#22d3ee;"></strong></span>
      <button id="chat-name-edit" style="background:none;border:none;color:#6b7280;font-size:.7rem;cursor:pointer;padding:0;">✏️ Edit</button>
    </div>
    <div class="chat-messages" id="chat-messages">
      <div style="display:flex;flex-direction:column;align-items:flex-start;margin-bottom:.75rem;"><span style="font-size:.65rem;font-weight:600;margin-bottom:.2rem;padding:0 .2rem;color:#9ca3af;">MLEbotics</span><div style="max-width:78%;border-radius:1rem;border-top-left-radius:.2rem;padding:.45rem .75rem;font-size:.85rem;line-height:1.5;background:#1f2937;color:#f3f4f6;">👋 Welcome to MLEbotics Community Chat! Ask questions, share what you're building, or just say hi.</div></div>
    </div>
    <div class="chat-input-row" id="chat-input-row">
      <input id="chat-input" type="text" placeholder="Type a message…" class="chat-input" autocomplete="off" />
      <button id="chat-send" class="chat-send-btn" aria-label="Send">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
  <button id="chat-fab" class="chat-fab" aria-label="Community chat">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    Community
  </button>
</div>

<script is:inline>
  const FIREBASE_CFG = {
    apiKey: 'AIzaSyDTJWhkRNMa5lOSdwxGLUGrpvWXrLuljfc', // pragma: allowlist secret
    authDomain: 'running-companion-a935f.firebaseapp.com',
    projectId: 'running-companion-a935f',
    storageBucket: 'running-companion-a935f.firebasestorage.app',
    messagingSenderId: '618174257557',
    appId: '1:618174257557:web:29ca5df050bd6daae9be9c'
  };
  const LOCAL_DRAFT_KEY = 'mlebotics_chat_draft';
  const LOCAL_NAME_KEY  = 'mlebotics_chat_name';
  const FB_VER = '10.12.2';

  const widget      = document.getElementById('chat-widget');
  const panel       = document.getElementById('chat-panel');
  const fab         = document.getElementById('chat-fab');
  const closeBtn    = document.getElementById('close-chat');
  const input       = document.getElementById('chat-input');
  const sendBtn     = document.getElementById('chat-send');
  const msgs        = document.getElementById('chat-messages');
  const openBtn     = document.getElementById('open-chat-btn');
  const nameScreen  = document.getElementById('chat-name-screen');
  const nameBar     = document.getElementById('chat-name-bar');
  const nameInput   = document.getElementById('chat-name-input');
  const nameSaveBtn = document.getElementById('chat-name-save');
  const nameDisplay = document.getElementById('chat-name-display');
  const nameEditBtn = document.getElementById('chat-name-edit');
  const inputRow    = document.getElementById('chat-input-row');

  widget.hidden = false;

  let currentName = localStorage.getItem(LOCAL_NAME_KEY) || '';

  // Restore draft
  input.value = localStorage.getItem(LOCAL_DRAFT_KEY) || '';
  input.addEventListener('input', () => localStorage.setItem(LOCAL_DRAFT_KEY, input.value));

  function formatTimestamp(seconds) {
    const d = new Date(seconds * 1000);
    const now = new Date();
    const isToday = d.toDateString() === now.toDateString();
    const time = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    return isToday ? 'Today · ' + time : d.toLocaleDateString([], { month: 'short', day: 'numeric' }) + ' · ' + time;
  }

  function showChatUI() {
    nameScreen.style.display = 'none';
    nameBar.style.display = 'flex';
    msgs.style.display = '';
    inputRow.style.display = '';
    nameDisplay.textContent = currentName;
    setTimeout(() => { input.focus(); msgs.scrollTop = msgs.scrollHeight; }, 50);
  }

  function showNameScreen(editing) {
    nameInput.value = editing ? currentName : '';
    nameInput.placeholder = editing ? 'Change your name…' : 'Enter your name…';
    nameSaveBtn.textContent = editing ? 'Save' : 'Join Chat';
    const btns = document.getElementById('chat-name-btns');
    if (editing) {
      if (!document.getElementById('chat-name-cancel')) {
        const cancelBtn = document.createElement('button');
        cancelBtn.id = 'chat-name-cancel';
        cancelBtn.textContent = 'Cancel';
        cancelBtn.style.cssText = 'flex:1;background:none;border:1px solid #374151;color:#9ca3af;font-size:.85rem;border-radius:8px;padding:.6rem;cursor:pointer;';
        cancelBtn.addEventListener('click', () => { document.getElementById('chat-name-cancel').remove(); showChatUI(); });
        btns.insertBefore(cancelBtn, nameSaveBtn);
      }
    } else {
      const c = document.getElementById('chat-name-cancel');
      if (c) c.remove();
    }
    nameScreen.style.display = '';
    nameBar.style.display = 'none';
    msgs.style.display = 'none';
    inputRow.style.display = 'none';
    setTimeout(() => nameInput.focus(), 50);
  }

  // Initialize
  if (currentName) { showChatUI(); } else { showNameScreen(false); }

  function saveName() {
    const trimmed = nameInput.value.trim();
    if (!trimmed) return;
    currentName = trimmed;
    localStorage.setItem(LOCAL_NAME_KEY, currentName);
    const c = document.getElementById('chat-name-cancel');
    if (c) c.remove();
    showChatUI();
  }
  nameSaveBtn.addEventListener('click', saveName);
  nameInput.addEventListener('keydown', e => { if (e.key === 'Enter') saveName(); });
  nameEditBtn.addEventListener('click', () => showNameScreen(true));

  // Online/offline indicator
  let offlineBanner = null;
  function updateOnlineStatus() {
    if (!navigator.onLine) {
      if (!offlineBanner) {
        offlineBanner = document.createElement('div');
        offlineBanner.style.cssText = 'background:#b45309;color:#fff;font-size:.75rem;padding:.35rem .75rem;text-align:center;';
        offlineBanner.textContent = '⚠ Offline — messages will sync when reconnected';
        panel.insertBefore(offlineBanner, inputRow);
      }
    } else {
      if (offlineBanner) { offlineBanner.remove(); offlineBanner = null; }
    }
  }
  window.addEventListener('online', updateOnlineStatus);
  window.addEventListener('offline', updateOnlineStatus);
  updateOnlineStatus();

  function togglePanel(show) {
    panel.hidden = !show;
    if (show) {
      if (!currentName) showNameScreen(false);
      else showChatUI();
    }
  }
  fab.addEventListener('click', () => { togglePanel(panel.hidden); unreadCount = 0; updateBadge(); });
  closeBtn.addEventListener('click', () => togglePanel(false));
  openBtn && openBtn.addEventListener('click', () => { togglePanel(true); setTimeout(() => widget.scrollIntoView({ behavior: 'smooth', block: 'end' }), 50); });

  const renderedIds = new Set();
  function renderMsg(id, text, fromType, senderName, tsSeconds) {
    if (renderedIds.has(id)) return;
    renderedIds.add(id);
    const isMe = senderName && currentName && senderName === currentName;
    const wrapper = document.createElement('div');
    wrapper.id = 'cmsg-' + id;
    wrapper.style.cssText = 'display:flex;flex-direction:column;' + (isMe ? 'align-items:flex-end;' : 'align-items:flex-start;') + 'margin-bottom:.75rem;';

    // Name label
    const nameEl = document.createElement('span');
    nameEl.style.cssText = 'font-size:.65rem;font-weight:600;margin-bottom:.2rem;padding:0 .2rem;color:' + (isMe ? '#22d3ee' : '#9ca3af') + ';';
    nameEl.textContent = isMe ? 'You' : (senderName || 'Anonymous');
    wrapper.appendChild(nameEl);

    // Bubble
    const bubble = document.createElement('div');
    bubble.style.cssText = 'max-width:78%;border-radius:1rem;padding:.45rem .75rem;font-size:.85rem;line-height:1.5;word-break:break-word;' +
      (isMe
        ? 'background:#06b6d4;color:#030712;border-top-right-radius:.2rem;'
        : 'background:#1f2937;color:#f3f4f6;border-top-left-radius:.2rem;');
    bubble.textContent = text;
    wrapper.appendChild(bubble);

    // Timestamp
    if (tsSeconds) {
      const tsEl = document.createElement('span');
      tsEl.style.cssText = 'font-size:.7rem;color:#9ca3af;margin-top:.2rem;padding:0 .2rem;';
      tsEl.textContent = formatTimestamp(tsSeconds);
      wrapper.appendChild(tsEl);
    }

    msgs.appendChild(wrapper);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function escHtml(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // Message count badge on FAB
  let unreadCount = 0;
  function updateBadge() {
    let badge = fab.querySelector('.chat-badge');
    if (unreadCount > 0 && panel.hidden) {
      if (!badge) { badge = document.createElement('span'); badge.className = 'chat-badge'; badge.style.cssText = 'position:absolute;top:-4px;right:-4px;background:#ef4444;color:#fff;border-radius:99px;font-size:.65rem;min-width:16px;height:16px;display:flex;align-items:center;justify-content:center;padding:0 3px;'; fab.style.position='relative'; fab.appendChild(badge); }
      badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
    } else if (badge) { badge.remove(); }
  }

  let sendMsgFn = null;

  // Firebase via CDN dynamic import
  import('https://www.gstatic.com/firebasejs/' + FB_VER + '/firebase-app.js').then(({ initializeApp, getApps }) => {
    const app = getApps().length === 0 ? initializeApp(FIREBASE_CFG) : getApps()[0];
    import('https://www.gstatic.com/firebasejs/' + FB_VER + '/firebase-firestore.js').then(({ getFirestore, enableIndexedDbPersistence, collection, addDoc, query, orderBy, limit, onSnapshot, serverTimestamp }) => {
      const db = getFirestore(app);
      enableIndexedDbPersistence(db).catch(() => {});
      const q = query(collection(db, 'community_chat'), orderBy('createdAt', 'asc'), limit(60));
      onSnapshot(q, snapshot => {
        snapshot.docChanges().forEach(change => {
          if (change.type === 'added') {
            const data = change.doc.data({ serverTimestamps: 'estimate' });
            renderMsg(change.doc.id, data.text, data.from || 'user', data.name, data.createdAt?.seconds ?? null);
            if (panel.hidden) { unreadCount++; updateBadge(); }
          }
        });
      });
      sendMsgFn = async (text) => {
        await addDoc(collection(db, 'community_chat'), { text, from: 'user', name: currentName || 'Anonymous', createdAt: serverTimestamp() });
      };
    });
  }).catch(() => {
    sendMsgFn = async (text) => { renderMsg('local-' + Date.now(), text, 'user', currentName || 'Anonymous', null); };
  });

  async function handleSend() {
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    localStorage.removeItem(LOCAL_DRAFT_KEY);
    sendBtn.disabled = true;
    try {
      if (sendMsgFn) await sendMsgFn(text);
      else renderMsg('local-' + Date.now(), text, 'user', currentName || 'Anonymous', null);
    } finally { sendBtn.disabled = false; }
  }

  sendBtn.addEventListener('click', handleSend);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') handleSend(); });
</script>

<style>
  /* Hero */
  .hero { position: relative; overflow: hidden; padding-top: 7rem; padding-bottom: 7rem; text-align: center; }
  .hero__inner { position: relative; z-index: 1; }
  .hero__badge {
    display: inline-flex; align-items: center; gap: .5rem;
    font-size: .75rem; font-weight: 500; letter-spacing: .08em; text-transform: uppercase;
    color: var(--cyan); border: 1px solid rgba(0,212,255,.25); border-radius: 99px;
    padding: .35rem 1rem; margin-bottom: 2rem;
  }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); box-shadow: 0 0 6px var(--green); }
  .hero__h1 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 700; line-height: 1.1; margin-bottom: 1.5rem; color: #fff; }
  .hero__sub { font-size: 1.1rem; color: var(--muted); margin-bottom: 2.5rem; line-height: 1.8; }
  .hero__cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .hero__glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 70% 55% at 50% 35%, rgba(0,212,255,.07) 0%, transparent 70%);
  }

  /* Section heading */
  .section__h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; color: #fff; margin-bottom: 2.5rem; }

  /* Capabilities grid */
  .grid3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
  .cap-card { display: flex; flex-direction: column; gap: .75rem; }
  .cap-icon { font-size: 1.75rem; }
  .cap-card h3 { font-size: 1rem; font-weight: 600; color: #fff; }
  .cap-card p { font-size: .875rem; color: var(--muted); line-height: 1.7; }

  /* Projects list */
  .project-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .project-card { text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: .6rem; }
  .project-card:hover h3 { color: var(--cyan); }
  .project-card__head { display: flex; justify-content: space-between; align-items: center; }
  .project-badge { font-size: .7rem; color: var(--muted); }
  .project-status { font-size: .65rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; padding: .2rem .55rem; border-radius: 99px; }
  .project-status.active { background: rgba(0,255,136,.12); color: var(--green); }
  .project-status.wip    { background: rgba(0,212,255,.12); color: var(--cyan); }
  .project-card h3 { font-size: 1.05rem; font-weight: 600; color: #fff; transition: color .15s; }
  .project-card p  { font-size: .875rem; color: var(--muted); line-height: 1.7; }


  /* CTA banner */
  .cta-banner {
    background: linear-gradient(135deg, rgba(0,212,255,.08), rgba(0,255,136,.05));
    border: 1px solid rgba(0,212,255,.2);
    border-radius: 16px;
    padding: 4rem 2rem;
    text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 1.25rem;
  }
  .cta-banner h2 { font-size: 2rem; font-weight: 700; color: #fff; }
  .cta-banner p  { font-size: 1rem; color: var(--muted); max-width: 480px; line-height: 1.7; }

  /* Community section */
  .community-card {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
    background: linear-gradient(135deg, rgba(0,212,255,.06), rgba(0,255,136,.04));
    border: 1px solid rgba(0,212,255,.18); border-radius: 20px; padding: 3rem;
  }
  @media (max-width: 768px) { .community-card { grid-template-columns: 1fr; } }
  .community-desc { font-size: .925rem; color: var(--muted); line-height: 1.75; margin-bottom: 1.75rem; }
  .community-btn { display: inline-flex; align-items: center; gap: .6rem; }

